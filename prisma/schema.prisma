// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_DEV")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  firstName      String?
  lastName       String?
  passwordHash   String
  refreshTokens  RefreshToken[]
  lessonProgress LessonProgress[]
  favourites     Favourite[]
  settings       UserSettings?
  createdAt      DateTime         @default(now())
}

enum Voice {
  m
  f
}

enum Theme {
  light
  dark
}

model UserSettings {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voice     Voice    @default(m)
  theme     Theme    @default(light)
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Track {
  id          String   @id
  title       Json
  description Json
  position    Int      @default(0)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id        String           @id
  trackId   String
  track     Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  title     Json
  context   Json
  version   Int              @default(1)
  position  Int              @default(0)
  changelog Json
  steps     LessonStep[]
  progress  LessonProgress[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

enum StepKind {
  teach
  assemble
  speak
  listen
  dialog
}

model LessonStep {
  id           String                  @id @default(uuid())
  lessonId     String
  lesson       Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  position     Int
  kind         StepKind
  sentenceId   String?
  sentence     Sentence?               @relation(fields: [sentenceId], references: [id], onDelete: SetNull)
  dialogId     String?
  dialog       Dialog?                 @relation(fields: [dialogId], references: [id], onDelete: SetNull)
  patternId    String?
  pattern      Pattern?                @relation(fields: [patternId], references: [id], onDelete: SetNull)
  grammarNotes LessonStepGrammarNote[]
  siblings     LessonStepSibling[]
}

model LessonStepSibling {
  lessonStepId String
  lessonStep   LessonStep @relation(fields: [lessonStepId], references: [id], onDelete: Cascade)
  sentenceId   String
  sentence     Sentence   @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  position     Int

  @@id([lessonStepId, sentenceId])
}

model Pattern {
  id               String               @id
  explanation      Json
  slotType         String
  grammarNotes     PatternGrammarNote[]
  sentencePatterns SentencePattern[]
  lessonSteps      LessonStep[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model SentencePattern {
  sentenceId      String
  sentence        Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  patternId       String
  pattern         Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)
  focusTokenIndex Int

  @@id([sentenceId, patternId])
}

model GrammarNote {
  id                     String                  @id
  title                  Json?
  body                   Json
  deeper                 Json?
  patterns               PatternGrammarNote[]
  tokens                 Token[]
  sentenceGrammarNotes   SentenceGrammarNote[]
  lessonStepGrammarNotes LessonStepGrammarNote[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model SentenceGrammarNote {
  sentenceId    String
  sentence      Sentence    @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  grammarNoteId String
  grammarNote   GrammarNote @relation(fields: [grammarNoteId], references: [id], onDelete: Cascade)
  position      Int         @default(0)

  @@id([sentenceId, grammarNoteId])
}

model LessonStepGrammarNote {
  lessonStepId  String
  lessonStep    LessonStep  @relation(fields: [lessonStepId], references: [id], onDelete: Cascade)
  grammarNoteId String
  grammarNote   GrammarNote @relation(fields: [grammarNoteId], references: [id], onDelete: Cascade)
  position      Int         @default(0)

  @@id([lessonStepId, grammarNoteId])
}

model PatternGrammarNote {
  patternId     String
  pattern       Pattern     @relation(fields: [patternId], references: [id], onDelete: Cascade)
  grammarNoteId String
  grammarNote   GrammarNote @relation(fields: [grammarNoteId], references: [id], onDelete: Cascade)
  position      Int         @default(0)

  @@id([patternId, grammarNoteId])
}

model SynonymGroup {
  id        String          @id
  meaning   Json
  members   SynonymMember[]
  tokens    Token[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum Register {
  casual
  neutral
  polite
  humble
}

model SynonymMember {
  id             String       @id
  synonymGroupId String
  synonymGroup   SynonymGroup @relation(fields: [synonymGroupId], references: [id], onDelete: Cascade)
  tokenId        String
  token          Token        @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  register       Register?
  note           Json?
}

enum TokenType {
  noun
  pronoun
  verb
  adjective
  adverb
  particle
  ending
  prefix
  number
  counter
  expression
  other
}

model Token {
  id             String          @id
  surface        String
  reading        String
  romaji         String
  cyrillic       String
  gloss          Json
  type           TokenType
  grammarNoteId  String?
  grammarNote    GrammarNote?    @relation(fields: [grammarNoteId], references: [id], onDelete: SetNull)
  synonymGroupId String?
  synonymGroup   SynonymGroup?   @relation(fields: [synonymGroupId], references: [id], onDelete: SetNull)
  sentenceTokens SentenceToken[]
  synonymMembers SynonymMember[]
  favourites     Favourite[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Sentence {
  id            String                @id
  translation   Json
  romaji        String
  cyrillicGuide Json
  tokens        SentenceToken[]
  dialogTurns   DialogTurn[]
  lessonSteps   LessonStep[]
  siblingOf     LessonStepSibling[]
  favourites    Favourite[]
  grammarNotes  SentenceGrammarNote[]
  patterns      SentencePattern[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model SentenceToken {
  id         String   @id @default(uuid())
  sentenceId String
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  tokenId    String
  token      Token    @relation(fields: [tokenId], references: [id], onDelete: Restrict)
  position   Int
  before     String?
  after      String?
}

model Dialog {
  id          String       @id
  title       Json
  turns       DialogTurn[]
  lessonSteps LessonStep[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum Speaker {
  user
  staff
}

model DialogTurn {
  id         String   @id @default(uuid())
  dialogId   String
  dialog     Dialog   @relation(fields: [dialogId], references: [id], onDelete: Cascade)
  position   Int
  speaker    Speaker
  sentenceId String
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Restrict)
}

enum LessonStatus {
  available
  in_progress
  completed
}

model LessonProgress {
  id                 String       @id @default(uuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId           String
  lesson             Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status             LessonStatus
  currentStep        Int          @default(0)
  completedAt        DateTime?
  completedAtVersion Int?
  hintsUsed          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([userId, lessonId])
}

enum FavouriteItemType {
  token
  sentence
}

model Favourite {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType   FavouriteItemType
  tokenId    String?
  token      Token?            @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  sentenceId String?
  sentence   Sentence?         @relation(fields: [sentenceId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([userId, tokenId])
  @@unique([userId, sentenceId])
}

model ContentEmbedding {
  kind      String // 'token' | 'sentence' | 'note' | 'pattern' | 'lesson'
  entityId  String
  model     String
  textHash  String
  text      String
  embedding Unsupported("vector(2560)")
  updatedAt DateTime                    @updatedAt

  @@id([kind, entityId])
}
