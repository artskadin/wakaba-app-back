{
  "potential": {
    "id": "potential",
    "title": {
      "ru": "hanasemasu — «могу говорить», hanasemasen — «не могу говорить»"
    },
    "body": [
      {
        "summary": {
          "ru": "Есть базовый глагол 話す hanasu [ханасу] со значением «говорить»."
        },
        "details": [
          {
            "ru": "Его потенциальная форма 話せる hanaseru [ханасэру] — «уметь / мочь говорить»."
          },
          {
            "ru": "«Потенциальная форма» — это форма глагола, которая в японском выражает возможность или способность «что-либо сделать»."
          }
        ],
        "examples": [
          {
            "kind": "transform",
            "from": {
              "surface": "話す",
              "romaji": "hanasu",
              "cyrillic": "ханасу"
            },
            "to": {
              "surface": "話せる",
              "romaji": "hanaseru",
              "cyrillic": "ханасэру"
            },
            "note": {
              "ru": "говорить → мочь говорить"
            }
          }
        ]
      },
      {
        "summary": {
          "ru": "hanasemasu — «(я) могу говорить» (вежливая форма утверждения)."
        },
        "details": [
          {
            "ru": "Чтобы придать глаголу вежливую форму, добавляют окончание '-masu'. Получается: hanaseru → hanasemasu."
          }
        ],
        "examples": [
          {
            "kind": "transform",
            "from": {
              "surface": "話せる",
              "romaji": "hanaseru",
              "cyrillic": "ханасэру"
            },
            "to": {
              "surface": "話せます",
              "romaji": "hanasemasu",
              "cyrillic": "ханасэмас"
            },
            "note": {
              "ru": "мочь говорить → вежливо «могу говорить»"
            }
          }
        ]
      },
      {
        "summary": {
          "ru": "hanasemasen — «(я) не могу говорить» (вежливая форма отрицания)."
        },
        "details": [
          {
            "ru": "Чтобы придать глаголу вежливую форму отрицания, добавляют окончание '-masen'. Получается: hanaseru → hanasemasen."
          }
        ],
        "examples": [
          {
            "kind": "transform",
            "from": {
              "surface": "話せる",
              "romaji": "hanaseru",
              "cyrillic": "ханасэру"
            },
            "to": {
              "surface": "話せません",
              "romaji": "hanasemasen",
              "cyrillic": "ханасэмасэн"
            },
            "note": {
              "ru": "мочь говорить → вежливо «не могу говорить»"
            }
          }
        ]
      }
    ],
    "deeper": [
      {
        "summary": {
          "ru": "Не путайте с глаголом 話します hanashimasu [ханасимас] — «говорю», без оттенка «могу»."
        },
        "details": [
          {
            "ru": "Здесь акцент на действие «говорить», а не на возможности «могу говорить»."
          }
        ],
        "examples": [
          {
            "kind": "phrase",
            "forms": [
              {
                "surface": "友達と話します",
                "romaji": "tomodachi to hanashimasu",
                "cyrillic": "томодати то ханасимас"
              }
            ],
            "note": {
              "ru": "Я разговариваю с другом"
            }
          }
        ]
      }
    ]
  }
}
